#!/usr/bin/env python3
"""
DESCRIPTION: Regenerates rulesync outputs after rebase or commit --amend.

BEHAVIOR:
  1. Walks up from CWD to find the repo root via `git rev-parse`.
  2. Delegates to rulesync_hook.regenerate_if_needed, which auto-skips when
     `rulesync.jsonc` is missing or generated outputs are already up to date.

  The mtime-based check inside regenerate_if_needed handles whether anything
  actually changed — we don't need to inspect the rewritten-commits stdin.

EXIT CODES:
  Always 0 — hooks must not break rebases.

SETUP:
  See README.md. Installed as part of git-hooks-toolbox via
  `git config --global core.hooksPath ~/.git-hooks-toolbox`.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import rulesync_hook  # noqa: E402


def main() -> int:
    repo_root = rulesync_hook.repo_root_from_cwd()
    if repo_root:
        rulesync_hook.regenerate_if_needed(repo_root)
    return 0


if __name__ == "__main__":
    sys.exit(main())
